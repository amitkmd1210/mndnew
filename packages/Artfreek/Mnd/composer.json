{
    "name": "artfreek/mnd",
    "description": "A custom Laravel package",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Artfreek\\Mnd\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Artfreek\\Mnd\\MndServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}